# ==============================================================
# .gitignore per progetto LaTeX
# ==============================================================

# --- File di compilazione LaTeX ---
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.run.xml
*.synctex.gz
*.toc
*.lof
*.lot
*.nav
*.snm
*.vrb

# --- File intermedi ---
*.dvi
*.xdv
*.pdfsync

# --- Cache del pacchetto minted (evidenziazione codice) ---
_minted-*/
*.data.minted
*.pyg

# --- PDF generato (opzionale: rimuovi questa riga se vuoi committare il PDF) ---
main.pdf

# --- Editor ---
.vscode/
*.code-workspace
*.texpadtmp

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini
