# ==============================================================
# .gitignore per progetto LaTeX
# ==============================================================

# --- File di compilazione LaTeX ---
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.run.xml
*.synctex.gz
*.toc
*.lof
*.lot
*.nav
*.snm
*.vrb

# --- File intermedi ---
*.dvi
*.xdv
*.pdfsync

# --- Cache del pacchetto minted (evidenziazione codice) ---
_minted-*/
*.data.minted
*.pyg

# --- PDF generato (opzionale: rimuovi questa riga se vuoi committare il PDF) ---
main.pdf

# --- Editor ---
.vscode/
*.code-workspace
*.texpadtmp

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Sessione Copilot: automazioni locali ---
tools/update_registro.py
tools/analizza_appunti.py
tools/verifica_completa.py
reports/verifica_appunti.md

# --- Materiale di studio non versionato ---
Dispensa11-12.pdf
Metodi_Numerici_per_l'Algebra_Lineare.pdf
reports/scheda_dispense.md
